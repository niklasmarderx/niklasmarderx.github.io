---
interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description = 'Software Engineer at SAP · MSc Student at Uni Potsdam · Rust, TypeScript, AI agents & developer tools',
} = Astro.props;

const pageTitle = title ? `${title} · Niklas Marder` : 'Niklas Marder';
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <nav class="container">
        <a href="/" class="site-name">Niklas Marder</a>
        <div class="nav-links">
          <a href="/#projects" class={currentPath === '/' ? 'active' : ''}>Projects</a>
          <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>Blog</a>
          <a href="/cv" class={currentPath === '/cv' ? 'active' : ''}>CV</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>
          © 2026 Niklas Marder ·
          <a href="https://github.com/niklasmarderx" target="_blank" rel="noopener">GitHub</a>
          ·
          <a
            href="https://www.linkedin.com/in/niklas-marder-75263a164/"
            target="_blank"
            rel="noopener">LinkedIn</a
          >
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #ffffff;
    --bg-subtle: #f9fafb;
    --border: #e5e7eb;
    --fg: #111827;
    --fg-muted: #6b7280;
    --fg-subtle: #9ca3af;
    --accent: #2563eb;
    --accent-hover: #1d4ed8;
    --radius: 8px;
    --max-w: 780px;
  }

  html {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    color: var(--accent-hover);
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Nav */
  header {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .site-name {
    font-weight: 600;
    color: var(--fg);
    font-size: 0.95rem;
    letter-spacing: -0.01em;
  }

  .site-name:hover {
    color: var(--fg);
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: var(--fg-muted);
    font-weight: 500;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 5rem;
  }

  footer p {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  footer a {
    color: var(--fg-muted);
  }

  footer a:hover {
    color: var(--fg);
  }

  /* Section headings */
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin-bottom: 1.25rem;
  }

  /* Tag badges */
  .tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    background: var(--bg-subtle);
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.15s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid var(--accent);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
    border-color: var(--accent-hover);
  }

  .btn-secondary {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--bg-subtle);
    color: var(--fg);
  }
</style>
