---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="container page">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
        {post.data.tags?.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <h1>{post.data.title}</h1>
      <p class="post-desc">{post.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog">← Back to all posts</a>
    </footer>
  </article>
</Layout>

<style>
  .page {
    padding: 3.5rem 1.5rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .post-meta time {
    font-size: 0.85rem;
    color: var(--fg-subtle);
  }

  .post-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-desc {
    font-size: 1.05rem;
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 580px;
  }

  /* Prose styles */
  .prose {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--fg);
    max-width: 660px;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.5rem 0 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: #374151;
  }

  .prose :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.875em;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: #0d1117;
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #e6edf3;
    font-size: 0.875rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
    color: #374151;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--fg-muted);
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-footer a {
    font-size: 0.9rem;
    color: var(--fg-muted);
  }

  .post-footer a:hover {
    color: var(--fg);
  }
</style>
