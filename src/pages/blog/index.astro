---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="Writing on Rust, AI agents, developer tooling, and software engineering.">
  <section class="container page">
    <div class="page-header">
      <h1>Writing</h1>
      <p class="page-subtitle">Thoughts on Rust, AI agents, developer tooling, and software engineering.</p>
    </div>

    {
      posts.length === 0 ? (
        <p class="empty">No posts yet — check back soon.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-item">
              <div class="post-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags?.map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <p class="post-title">{post.data.title}</p>
              <p class="post-desc">{post.data.description}</p>
            </a>
          ))}
        </div>
      )
    }
  </section>
</Layout>

<style>
  .page {
    padding: 3.5rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    color: var(--fg-muted);
    font-size: 0.975rem;
  }

  .empty {
    color: var(--fg-muted);
    font-size: 0.975rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: block;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--fg);
    transition: opacity 0.15s;
  }

  .post-item:hover {
    opacity: 0.7;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--fg-subtle);
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 580px;
  }
</style>
