---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Software Engineer',
    company: 'SAP',
    period: '2023 – present',
    description:
      'Working on enterprise software systems, backend development, and internal developer tooling.',
  },
];

const education = [
  {
    degree: 'MSc Computer Science',
    institution: 'University of Potsdam',
    period: '2024 – present',
    description:
      'Research focus on enterprise software architectures and process coherence. Thesis: Process Coherence als Bewertungskriterium von ESA.',
  },
  {
    degree: 'BSc Computer Science',
    institution: 'University of Potsdam',
    period: '2020 – 2024',
    description: 'Foundation in algorithms, data structures, distributed systems, and software engineering.',
  },
];

const skills = {
  Languages: ['Rust', 'TypeScript', 'Python', 'Java', 'LaTeX'],
  Interests: ['AI agents', 'Developer tooling', 'Distributed systems', 'CLI tools', 'Open source'],
};
---

<Layout title="CV" description="Niklas Marder — Software Engineer at SAP, MSc student at Uni Potsdam.">
  <section class="container page">
    <div class="page-header">
      <h1>Curriculum Vitae</h1>
      <div class="cv-links">
        <a href="https://github.com/niklasmarderx" target="_blank" rel="noopener">GitHub ↗</a>
        <a
          href="https://www.linkedin.com/in/niklas-marder-75263a164/"
          target="_blank"
          rel="noopener">LinkedIn ↗</a
        >
        <a href="mailto:">Contact</a>
      </div>
    </div>

    <!-- Experience -->
    <div class="cv-section">
      <p class="section-label">Experience</p>
      <div class="timeline">
        {
          experience.map((e) => (
            <div class="timeline-item">
              <div class="timeline-header">
                <div>
                  <span class="timeline-role">{e.role}</span>
                  <span class="timeline-company"> · {e.company}</span>
                </div>
                <span class="timeline-period">{e.period}</span>
              </div>
              <p class="timeline-desc">{e.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Education -->
    <div class="cv-section">
      <p class="section-label">Education</p>
      <div class="timeline">
        {
          education.map((e) => (
            <div class="timeline-item">
              <div class="timeline-header">
                <div>
                  <span class="timeline-role">{e.degree}</span>
                  <span class="timeline-company"> · {e.institution}</span>
                </div>
                <span class="timeline-period">{e.period}</span>
              </div>
              <p class="timeline-desc">{e.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Skills -->
    <div class="cv-section">
      <p class="section-label">Skills</p>
      <div class="skills-grid">
        {
          Object.entries(skills).map(([category, items]) => (
            <div class="skills-row">
              <span class="skills-category">{category}</span>
              <div class="skills-tags">
                {items.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Projects -->
    <div class="cv-section">
      <p class="section-label">Selected Open Source</p>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-header">
            <div>
              <a href="https://github.com/niklasmarderx/Ember" target="_blank" rel="noopener" class="timeline-role">Ember</a>
              <span class="timeline-company"> · Rust · AI agent framework</span>
            </div>
            <span class="timeline-period">★ 3</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-header">
            <div>
              <a href="https://github.com/niklasmarderx/rune" target="_blank" rel="noopener" class="timeline-role">rune</a>
              <span class="timeline-company"> · Rust · AI coding agent CLI</span>
            </div>
            <span class="timeline-period">★ 2</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-header">
            <div>
              <a href="https://github.com/niklasmarderx/hotswap" target="_blank" rel="noopener" class="timeline-role">hotswap</a>
              <span class="timeline-company"> · Rust · Zero-downtime config reloader</span>
            </div>
            <span class="timeline-period">★ 1</span>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-header">
            <div>
              <a href="https://github.com/niklasmarderx/TypeCraft" target="_blank" rel="noopener" class="timeline-role">TypeCraft</a>
              <span class="timeline-company"> · TypeScript · Typing trainer for programmers</span>
            </div>
            <span class="timeline-period">★ 1</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page {
    padding: 3.5rem 1.5rem;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .cv-links {
    display: flex;
    gap: 1.25rem;
  }

  .cv-links a {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  .cv-links a:hover {
    color: var(--fg);
  }

  .cv-section {
    margin-bottom: 3rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    padding: 1.1rem 0;
    border-top: 1px solid var(--border);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .timeline-role {
    font-weight: 600;
    font-size: 0.975rem;
    color: var(--fg);
  }

  a.timeline-role:hover {
    color: var(--accent);
  }

  .timeline-company {
    font-size: 0.9rem;
    color: var(--fg-muted);
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--fg-subtle);
    white-space: nowrap;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 560px;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .skills-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
  }

  .skills-category {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-muted);
    min-width: 100px;
    flex-shrink: 0;
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
